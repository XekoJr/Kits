services:
  postgres:
    image: postgres
    container_name: postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: 
      POSTGRES_USER: 
      POSTGRES_PASSWORD: 
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql

  web:
    build: .
    container_name: php
    restart: unless-stopped
    ports:
      - "8080:80"
      - "8001:8001"
    volumes:
      - ./www:/var/www/html
    depends_on:
      postgres:
        condition: service_healthy

volumes:
  postgres_data: